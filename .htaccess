# 1. FIX THE "SHOWING CODE" ISSUE
# Instead of 'Header set', we map the extension to the correct type
AddType application/json .ashx
AddType text/plain .ashz

# 2. THE PHP REDIRECT LOGIC
RewriteEngine On
RewriteBase /

# If the file exists, just serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If adding .php makes it a real file, use that
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L,QSA]
