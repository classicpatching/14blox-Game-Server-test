RewriteEngine On
RewriteBase /

# 1. THE URL CLEANER
# This makes /games/list work without needing .php in the URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*?)/?$ $1.php [L]

# 2. THE HEADER FIX (Without crashing the server)
# Instead of 'Header set', we use 'ForceType' inside location blocks
<Files "list.php">
    ForceType application/json
</Files>

<Files "PlaceLauncher.php">
    ForceType application/json
</Files>

<Files "visit.php">
    ForceType text/plain
</Files>
