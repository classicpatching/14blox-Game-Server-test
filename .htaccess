RewriteEngine On
RewriteBase /

# 1. REMOVE .PHP FROM URLS
# If the user asks for /games/list, the server looks for /games/list.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*?)/?$ $1.php [L]

# 2. FORCE JSON FOR THE GAMES LIST
# This prevents the app from showing raw code on the screen
<Files "list.php">
    AddType application/json .php
    Header set Content-Type "application/json"
</Files>

# 3. FORCE JSON FOR PLACELAUNCHER
<Files "PlaceLauncher.php">
    AddType application/json .php
    Header set Content-Type "application/json"
</Files>
