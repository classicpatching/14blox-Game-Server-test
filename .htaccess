RewriteEngine On

# Если обращаются к /join.ashx, отдаем содержимое /join.ashx/index.php
RewriteRule ^join\.ashx$ join.ashx/index.php [L]

# Если обращаются к /games/list, отдаем содержимое /games/list/index.php
RewriteRule ^games/list$ games/list/index.php [L]

# На всякий случай: если файла не существует, кидаем всё на главный index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . index.php [L]
