RewriteEngine On
RewriteBase /

# 1. Map .ashx requests to .php files silently
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)\.ashx$ $1.php [L,QSA]

# 2. Map .ashz requests to .php files (for your join script)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)\.ashz$ $1.php [L,QSA]

# 3. Ensure the server tells the app it's JSON
<FilesMatch "\.php$">
    # Only force JSON for the PlaceLauncher
    RewriteCond %{REQUEST_URI} PlaceLauncher
    RewriteRule ^ - [E=CONTENT_TYPE:application/json]
</FilesMatch>
